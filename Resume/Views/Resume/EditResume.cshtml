@model Tastehub.Model.ViewModel.EditResumeViewModel
@{
    ViewBag.Title = "Edit Resume";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-wrapper">
    <!-- Breadcrumb -->
    <div class="page-breadcrumb">
        <div class="row">
            <div class="col-12 d-flex no-block align-items-center">
                <h4 class="page-title">Edit Resume Details</h4>
                <div class="ml-auto text-right">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Resume</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    <!-- Container -->
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-9">
                <div class="card">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    @using (Html.BeginForm("EditResume", "Resume", FormMethod.Post,
                        new { @class = "form-horizontal", role = "form", enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <h4 class="card-title">Personal Info</h4>
                            @Html.HiddenFor(m => m.PersonalDetail.UserId)

                            <div class="form-group row">
                                <label class="col-sm-3 text-right control-label col-form-label">First Name</label>
                                <div class="col-sm-9">
                                    @Html.TextBoxFor(m => m.PersonalDetail.FirstName, new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.PersonalDetail.FirstName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-sm-3 text-right control-label col-form-label">Last Name</label>
                                <div class="col-sm-9">
                                    @Html.TextBoxFor(m => m.PersonalDetail.LastName, new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.PersonalDetail.LastName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-sm-3 text-right control-label col-form-label">Email</label>
                                <div class="col-sm-9">
                                    @Html.TextBoxFor(m => m.PersonalDetail.Email, new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.PersonalDetail.Email, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="form-group row">
                                <label class="col-sm-3 text-right control-label col-form-label">Phone</label>
                                <div class="col-sm-9">
                                    @Html.TextBoxFor(m => m.PersonalDetail.Phone, new { @class = "form-control" })
                                    @Html.ValidationMessageFor(m => m.PersonalDetail.Phone, "", new { @class = "text-danger" })
                                </div>
                            </div>

                            <h4 class="card-title">Education</h4>
                            @for (int i = 0; i < Model.Education.Count; i++)
                            {
                                @Html.HiddenFor(m => m.Education[i].Id)
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Degree</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Education[i].Degree, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Institution</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Education[i].Institution, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Year</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Education[i].YearOfPassing, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Grade</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Education[i].Grade, new { @class = "form-control" })</div>
                                </div>
                            }

                            <h4 class="card-title">Experience</h4>
                            @for (int i = 0; i < Model.Experience.Count; i++)
                            {
                                @Html.HiddenFor(m => m.Experience[i].Id)
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Company</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Experience[i].CompanyName, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Designation</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Experience[i].Designation, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Start Date</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Experience[i].StartDate, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">End Date</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Experience[i].EndDate, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Responsibilities</label>
                                    <div class="col-sm-9">@Html.TextAreaFor(m => m.Experience[i].Responsibilities, new { @class = "form-control" })</div>
                                </div>
                            }

                            <h4 class="card-title">Skills</h4>
                            @for (int i = 0; i < Model.Skills.Count; i++)
                            {
                                @Html.HiddenFor(m => m.Skills[i].Id)
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Skill</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Skills[i].SkillName, new { @class = "form-control" })</div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-sm-3 text-right control-label col-form-label">Proficiency</label>
                                    <div class="col-sm-9">@Html.TextBoxFor(m => m.Skills[i].ProficiencyLevel, new { @class = "form-control" })</div>
                                </div>
                            }
                        </div>

                        <div class="border-top">
                            <div class="card-body">
                                <button type="submit" class="btn btn-success">Save</button>
                                <a href="@Url.Action("ManageResumes", "Resume")" class="btn btn-danger">Cancel</a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <footer class="footer text-center">
        All Rights Reserved by . Designed and Developed by <a href="http://brajeshkumar.co.in/">Brajesh Kumar</a>.
    </footer>
</div>
